# ─── Database ────────────────────────────────────────────────────────────────
# Local: postgresql://veerha:veerha123@localhost:5432/veerha_wms_dev
# Production (Neon): get connection string from https://neon.tech
DATABASE_URL=postgresql://user:password@localhost:5432/veerha_wms_dev

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Dev:        http://localhost:8080,http://localhost:8090
# Production: https://veerha-wms.pages.dev,https://veerha-admin.pages.dev
CORS_ORIGIN=http://localhost:8080,http://localhost:8090

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long-change-this
